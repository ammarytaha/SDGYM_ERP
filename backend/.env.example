# Copy this file to .env and fill in real values. Never commit .env.

# Runtime
NODE_ENV=development
PORT=4000

# Postgres connection string used by both the app and node-pg-migrate.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres@localhost:5432/saad_gym

# JWT signing. Use a long, random string in every environment.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Comma-separated list of browser origins allowed by CORS (the React app).
CLIENT_ORIGIN=http://localhost:5173

# WhatsApp / Meta Cloud API (spec §8). OPTIONAL — leave blank for development.
# With no PHONE_NUMBER_ID + ACCESS_TOKEN the app runs in DRY-RUN mode: every
# notification is written to notifications_log (status 'sent') but NOT sent to Meta.
# Fill both in to go live. To set up:
#   1. Create a Meta app with the WhatsApp product -> free sandbox number + WABA.
#   2. Get the Phone Number ID and a permanent System-User access token.
#   3. Submit the templates for approval: welcome, checkin_confirmation,
#      renewal_reminder, payment_overdue.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_LANG=ar
# WHATSAPP_COUNTRY_CODE=20

# Schedule the daily reminder run (renewal + payment-overdue) with your OS
# scheduler, e.g. cron:  0 9 * * *  cd /path/to/backend && npm run reminders
