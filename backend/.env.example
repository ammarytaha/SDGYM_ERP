# Copy this file to .env and fill in real values. Never commit .env.

# Runtime
NODE_ENV=development
PORT=4000

# Postgres connection string used by both the app and node-pg-migrate.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres@localhost:5432/saad_gym

# JWT signing. Use a long, random string in every environment.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Comma-separated list of browser origins allowed by CORS (the React app).
CLIENT_ORIGIN=http://localhost:5173
